@startuml TortillaCloud_Architecture
title Tortilla Cloud - Application Architecture
left to right direction

skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle

package "Web MVC Layer" {
  [HomeController]
  [RegistrationController]
  [DesignTortillaController]
  [OrdersCurrentController]
}

package "Security Layer" {
  [SecurityConfig]
  [UserRepositoryUserDetailsService]
  [RegistrationForm]
  [PasswordEncoder]
}

package "Persistence Layer" {
  [UserRepository]
  [IngredientRepository]
  [TortillaRepository]
  [OrderRepository]
  database "H2 DB" as DB
}

package "Domain Model" {
  class User
  class Order
  class Tortilla
  class Ingredient
  enum Type
}

[SecurityConfig] --> [HomeController]
[SecurityConfig] --> [RegistrationController]
[SecurityConfig] --> [DesignTortillaController]
[SecurityConfig] --> [OrdersCurrentController]
[SecurityConfig] --> [UserRepositoryUserDetailsService]

[UserRepositoryUserDetailsService] --> [UserRepository]
[RegistrationController] --> [RegistrationForm]
[RegistrationController] --> [PasswordEncoder]
[RegistrationController] --> [UserRepository]

[DesignTortillaController] --> [IngredientRepository]
[DesignTortillaController] --> [TortillaRepository]
[OrdersCurrentController] --> [OrderRepository]

[UserRepository] --> DB
[IngredientRepository] --> DB
[TortillaRepository] --> DB
[OrderRepository] --> DB

User "1" <-- "0..*" Order : places
Order "0..*" -- "0..*" Tortilla : contains
Tortilla "1..*" -- "0..*" Ingredient : selected from
Ingredient --> Type : typed by

@enduml
