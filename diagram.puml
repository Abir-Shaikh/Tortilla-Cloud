@startuml TortillaCloud_Full_Architecture
title Tortilla Cloud - Full Application Architecture
left to right direction

skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle

actor "Browser User" as Browser

package "Entry / Bootstrapping" {
  [TortillaCloudApplication]
}

package "Web MVC Layer (Controllers)" {
  [HomeController]
  [RegistrationController]
  [DesignTortillaController]
  [OrdersCurrentController]
}

package "Security Layer" {
  [SecurityConfig]
  [UserRepositoryUserDetailsService]
  [RegistrationForm]
  [PasswordEncoder (BCrypt)]
  [Spring Security Filter Chain]
}

package "Configuration Layer" {
  [OrderProps]
  [application.properties]
}

package "Service Layer" {
  [UserDetailsService Contract]
}

package "Persistence Layer (Repositories)" {
  [UserRepository]
  [IngredientRepository]
  [TortillaRepository]
  [OrderRepository]
}

package "Domain Model (JPA Entities)" {
  [User Entity] as UserEntity
  [Order Entity] as OrderEntity
  [Tortilla Entity] as TortillaEntity
  [Ingredient Entity] as IngredientEntity
  [Type Enum] as TypeEnum
}

package "View Layer (Thymeleaf Templates)" {
  [home.html]
  [login.html]
  [registration.html]
  [design.html]
  [orderForm.html]
  [orderList.html]
}

database "H2 In-Memory DB" as DB
collections "data.sql" as SeedData

Browser --> [Spring Security Filter Chain]
[Spring Security Filter Chain] --> [HomeController]
[Spring Security Filter Chain] --> [RegistrationController]
[Spring Security Filter Chain] --> [DesignTortillaController]
[Spring Security Filter Chain] --> [OrdersCurrentController]

[SecurityConfig] --> [Spring Security Filter Chain]
[SecurityConfig] --> [UserRepositoryUserDetailsService]
[SecurityConfig] --> [PasswordEncoder (BCrypt)]

[UserRepositoryUserDetailsService] ..> [UserDetailsService Contract]
[UserRepositoryUserDetailsService] --> [UserRepository]

[RegistrationController] --> [RegistrationForm]
[RegistrationForm] --> [PasswordEncoder (BCrypt)]
[RegistrationForm] --> UserEntity : creates
[RegistrationController] --> [UserRepository]

[DesignTortillaController] --> [IngredientRepository]
[DesignTortillaController] --> [TortillaRepository]
[DesignTortillaController] --> TypeEnum

[OrdersCurrentController] --> [OrderRepository]
[OrdersCurrentController] --> [OrderProps]
[OrderProps] --> [application.properties]

[HomeController] --> [home.html]
[HomeController] --> [login.html]
[RegistrationController] --> [registration.html]
[DesignTortillaController] --> [design.html]
[OrdersCurrentController] --> [orderForm.html]
[OrdersCurrentController] --> [orderList.html]

[UserRepository] --> UserEntity
[IngredientRepository] --> IngredientEntity
[IngredientRepository] --> TypeEnum
[TortillaRepository] --> TortillaEntity
[OrderRepository] --> OrderEntity
[OrderRepository] --> UserEntity

UserEntity "1" <-- "0..*" OrderEntity : places
OrderEntity "0..*" -- "0..*" TortillaEntity : contains
TortillaEntity "1..*" -- "0..*" IngredientEntity : selected from
IngredientEntity --> TypeEnum : typed by

UserEntity --> DB
OrderEntity --> DB
TortillaEntity --> DB
IngredientEntity --> DB

SeedData --> IngredientEntity

@enduml
